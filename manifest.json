{
  "manifest_version": 3,
  "name": "Account Switcher for ERP&GMS",
  "version": "2.0",
  "description": "Account switcher for Geden Lines ERP & GMS portals with token file parsing and theming. By D/C Hakan Efe Gulacti",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://app.gedenlines.com/*",
    "https://gms.gedenlines.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "geden-logo.png",
      "32": "geden-logo.png",
      "48": "geden-logo.png",
      "128": "geden-logo.png"
    }
  },
  "icons": {
    "16": "geden-logo.png",
    "32": "geden-logo.png",
    "48": "geden-logo.png",
    "128": "geden-logo.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.gedenlines.com/*",
        "https://gms.gedenlines.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
