{
  "manifest_version": 3,
  "name": "Account Switcher for ERP",
  "version": "2.0",
  "description": "Account switcher for Geden Lines / Advantage Tankers ERP portals with token file parsing and theming. By D/C Hakan Efe Gulacti",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://app.gedenlines.com/*",
    "https://gms.gedenlines.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "advantage-logo.png",
      "32": "advantage-logo.png",
      "48": "advantage-logo.png",
      "128": "advantage-logo.png"
    }
  },
  "icons": {
    "16": "advantage-logo.png",
    "32": "advantage-logo.png",
    "48": "advantage-logo.png",
    "128": "advantage-logo.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.gedenlines.com/*",
        "https://gms.gedenlines.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
